{
  "firestore": {
    "rules": "firebase-app/firestore.rules",
    "indexes": "firebase-app/firestore.indexes.json"
  },
  "storage": {
    "rules": "firebase-app/storage.rules"
  },
  "functions": [
    {
      "source": "firebase-app/functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log"]
    }
  ],
  "hosting": [
    {
      "target": "admin",
      "public": "firebase-app/public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "lp",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "firebase-app/**",
        "gas-app/**",
        "scripts/**",
        "他社資料/**",
        "*.skill"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "assets/**",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=86400" }
          ]
        }
      ]
    }
  ]
}
